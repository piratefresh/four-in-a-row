{
  "name": "my-tanstack-app",
  "private": true,
  "type": "module",
  "engines": {
    "bun": "1.3.8",
    "node": "22"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "bunx srvx --prod --static ../client dist/server/server.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:preview": "bash scripts/run-e2e-preview.sh",
    "deploy:preview": "bash scripts/deploy-preview.sh",
    "deploy:convex:preview": "bun run deploy:preview",
    "deploy:convex:prod": "bunx convex deploy --env-file .env.convex-prod",
    "deploy:convex:prod:yes": "bunx convex deploy --env-file .env.convex-prod --yes",
    "deploy:convex:prod:dry-run": "bunx convex deploy --env-file .env.convex-prod --dry-run --yes",
    "deploy:prod": "bun run deploy:convex:prod && bun run deploy",
    "test:e2e:report": "playwright show-report",
    "test:e2e:trace": "playwright show-trace",
    "test:e2e:ui": "playwright test --ui",
    "generate:csw24-index": "node scripts/generate-csw24-index.mjs",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@cloudflare/vite-plugin": "^1.13.8",
    "@convex-dev/better-auth": "^0.10.10",
    "@convex-dev/react-query": "0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/react": "^0.3.2",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-serif": "^5.2.9",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/ai": "^0.10.2",
    "@tanstack/ai-openai": "^0.7.4",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "ai": "^6.0.97",
    "better-auth": "1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.36.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.575.0",
    "match-sorter": "^8.3.0",
    "motion": "^12.34.3",
    "next-themes": "^0.4.6",
    "nextstepjs": "^2.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-email": "^6.0.0",
    "resend": "^6.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.6",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.40.3"
  }
}
